# ============================================================
# JEEVANA REKHA — Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git
# ============================================================

# ── Payload CMS ──────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Random secret string (minimum 32 chars) — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# ── Server URLs ───────────────────────────────────────────────
# In development: http://localhost:3000
# In production: https://jeevanarekha.com
SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_CMS_URL=http://localhost:3000

# ── Google Analytics ─────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── AWS S3 (for image uploads) ───────────────────────────────
S3_BUCKET=jeevanarekha-media
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# Public CDN URL for uploaded images (use CloudFront in production)
NEXT_PUBLIC_S3_BASE_URL=https://<bucket>.s3.<region>.amazonaws.com
